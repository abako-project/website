# Copy this file as .env and fill in the values
# cp .env.example .env

# Base URL for all external APIs (Adapter, Virto, Kreivo, Contracts)
# All services live under this domain. Change this single value to switch environments.
# Examples:
#   Development: https://dev.abako.xyz
#   Production:  https://abako.xyz
VITE_API_BASE_URL=https://dev.abako.xyz

# Optional: Override Kreivo RPC URL independently (defaults to VITE_API_BASE_URL/kreivo)
# VITE_KREIVO_RPC_URL=
