

<style>
  .contenedor {
    display: grid;
    grid-template-columns: auto auto;
  }
</style>

<%- include('../components/_cancelTopbar', {step: 1}) %>

<div class="contenedor appHeader appHeader--votations">

  <div class="appHeader__left">
    <small class="link">
      <i class="ri-arrow-left-line"></i>
      <span> <%= voteData.project.title %> </span>
    </small>
    <h1 class="appHeader__title"><%= voteData.title %></h1>
    <p class="appHeader__subtitle"><%= voteData.subtitle %></p>
  </div>

  <div class="appHeader__right">
    <button class="btn btn_primary submitVotations">Submit Reviews</button>
  </div>

</div>

<% if (voteData.clientRating) { %>
    <section class="votations">
        <form id="voteForm" action="/projects/<%= voteData.project.id %>/clientRating" method="POST">
            <h1>Choose the evaluation for Consultant:</h1>
            <%- include('votationCard', { target: "consultant", member: voteData.clientRating.consultant, score: 0, readonly: false }) %>

            // Quitar si cliente no vota a developers
            <h1>Choose the evaluation for each Developer:</h1>
            <% voteData.clientRating.developers.forEach((member, index) => { %>
                <%- include('votationCard', {  target: "developer", member, score: 0, readonly: false }) %>
            <% }) %>
        </form>
    </section>
<% } %>

<% if (voteData.consultantRatings) { %>
    <section class="votations">
        <form id="voteForm" action="/projects/<%= voteData.project.id %>/consultantRatings" method="POST">
            <h1>Choose the evaluation for Client:</h1>
            <%- include('votationCard', {  target: "client", member: voteData.consultantRatings.client, score: 0, readonly: false }) %>

            <h1>Choose the evaluation for each Developer:</h1>
            <% voteData.consultantRatings.developers.forEach((member, index) => { %>
                <%- include('votationCard', {  target: "developer", member, score: 0, readonly: false }) %>
            <% }) %>
        </form>
    </section>
<% } %>

<% if (voteData.developerRating) { %>
    <section class="votations">
        <form id="voteForm" action="/projects/<%= voteData.project.id %>/developerRating" method="POST">
            <h1>Choose the evaluation for Consultant:</h1>
            <%- include('votationCard', {  target: "consultant", member: voteData.developerRating.consultant, score: 0, readonly: false }) %>
        </form>
    </section>
<% } %>


<script src="/javascripts/votations.js"></script>